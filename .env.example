# Kay — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real API keys.
#
# Load with: export $(cat .env.local | grep -v '^#' | xargs)

# MiniMax API key — used for live smoke tests (M12-Task 1) and EVAL-01a
# Get your key at: https://platform.minimax.io
# The MiniMax-M2.7 model is sufficient for EVAL-01a (no OpenRouter key required).
# Usage: export MINIMAX_API_KEY=$(cat ~/.minimax_api_key 2>/dev/null)
# MINIMAX_API_KEY=your_key_here
